# VCS / CI
.git
.github
.gitignore

# Reference repositories (huge; never part of the image)
prototype
ombi
overseerr
radarr
sonarr
jackett
prowlarr

# Local dev artifacts
.venv
venv
__pycache__
*.py[cod]
.pytest_cache
.coverage
coverage.xml
htmlcov
.pyright
.mypy_cache

# Scratch / data / secrets
.superpowers
data
*.db
*.sqlite3
.env
.plex-manager-updater-token

# Docs & tests are not needed at runtime
docs
tests

# Frontend: node_modules and any local build output are rebuilt in the image's
# Node stage. Excluding the local static build also ensures `COPY src ./src`
# never carries a stale UI — only the freshly built one (COPY --from=web) ships.
**/node_modules
frontend/dist
src/plex_manager/web/static
