# Plex Manager — bootstrap configuration.
#
# Only low-level bootstrap settings live here. Service credentials (Plex token,
# TMDB / Prowlarr / qBittorrent keys) are NOT set here — they are entered in the
# in-app setup wizard and stored encrypted in the database. See ADR-0005.
#
# Copy to `.env` and adjust as needed.

# Network
PLEX_MANAGER_HOST=0.0.0.0
# Host-facing bind/port for Docker Compose. The app listens on 8000 inside the
# container. Keep loopback for first setup; use a reverse proxy, SSH tunnel, or
# intentionally set 0.0.0.0 only after you understand the exposure.
PLEX_MANAGER_HOST_BIND=127.0.0.1
PLEX_MANAGER_HOST_PORT=8000

# Required by docker-compose.yml for first-run setup. Generate a fresh value:
#     python -c "import secrets; print(secrets.token_urlsafe(32))"
# The setup wizard asks for this token before service tests or completion.
PLEX_MANAGER_SETUP_TOKEN=

# Development only: skips both the setup-token and API-key gates. Leave false for
# Docker, shared, or network-exposed hosts.
PLEX_MANAGER_DEV_AUTH_BYPASS=false

# Public origin (scheme + host[:port], no trailing path) the browser uses to reach
# this app. REQUIRED behind a TLS-terminating reverse proxy: the Plex hosted-login
# callback URL is built from it, and when unset the app falls back to the request
# origin — which behind a proxy is the wrong, internal address (e.g.
# http://127.0.0.1:8000), producing a broken sign-in redirect. Leave unset for a
# direct local deployment. Example: https://plex-manager.example.com
PLEX_MANAGER_PUBLIC_BASE_URL=

# Force the Secure attribute on the auth session/CSRF cookies. Leave unset to infer
# it: cookies are Secure when PLEX_MANAGER_PUBLIC_BASE_URL is https:// (or the app
# is reached directly over https), and non-Secure for a plain-http LAN deployment.
# Set true only if you terminate TLS at a proxy but leave PUBLIC_BASE_URL unset;
# set false to override for an unusual setup. Values: true | false.
PLEX_MANAGER_AUTH_COOKIE_SECURE=

# Host paths mounted into the container. In setup, choose Plex movie folders under
# /media and ensure qBittorrent save/content paths resolve under /downloads.
PLEX_MANAGER_MEDIA_ROOT=/srv/media
PLEX_MANAGER_DOWNLOADS_ROOT=/srv/downloads

# Database (defaults to SQLite in the mounted data volume). The app talks to the
# database asynchronously, so use the async driver form (sqlite+aiosqlite / for
# Postgres, postgresql+asyncpg). A plain sync URL is coerced to the async driver
# at startup, but the async form is the documented, unambiguous default.
#
# The stock Docker image includes PostgreSQL drivers. For a local non-Docker
# install, install the extra first:
#     pip install '.[postgres]'
# which pulls asyncpg (async app) + psycopg2-binary (sync Alembic migrations).
PLEX_MANAGER_DATABASE_URL=sqlite+aiosqlite:///./data/plex_manager.db

# Logging: DEBUG | INFO | WARNING | ERROR
PLEX_MANAGER_LOG_LEVEL=INFO

# Container image to run (override per host / channel).
# Canary host uses :edge, release host uses :stable.
PLEX_MANAGER_IMAGE=ghcr.io/lunchbox951/plex-manager:stable
