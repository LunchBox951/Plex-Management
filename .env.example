# Plex Manager — bootstrap configuration.
#
# Only low-level bootstrap settings live here. Service credentials (Plex token,
# TMDB / Prowlarr / qBittorrent keys) are NOT set here — they are entered in the
# in-app setup wizard and stored encrypted in the database. See ADR-0005.
#
# Copy to `.env` and adjust as needed.

# Network
#
# PLEX_MANAGER_HOST is the address the APPLICATION PROCESS binds. Leave it
# unset/commented — under Compose AND bare-metal. The Dockerfile's own
# default (PLEX_MANAGER_HOST=0.0.0.0) applies inside the container, and
# PLEX_MANAGER_HOST_BIND below controls what the host exposes.
#
# docker-compose.yml loads this file via `env_file`, and Compose env_file
# entries OVERRIDE the image's Dockerfile ENV. Setting this to 127.0.0.1
# would bind the CONTAINER's loopback, not the host's — the published port
# becomes unreachable while the in-container healthcheck still passes. On
# bare-metal, leaving it unset gives the code default of 127.0.0.1 (loopback)
# so a copied .env cannot be claimed from the network before first-run setup
# (ADR-0016). Only uncomment and widen this for an intentional, understood
# bare-metal exposure behind your own proxy/tunnel — never under Compose:
# PLEX_MANAGER_HOST=0.0.0.0
#
# Upgrading an older checkout? If your .env still has an active
# PLEX_MANAGER_HOST=0.0.0.0, delete or comment it so bare-metal returns to loopback.
#
# PLEX_MANAGER_HOST_BIND is the Docker Compose PUBLISHED host socket (compose only,
# separate from the process bind above). Keep loopback for first setup; use a
# reverse proxy or SSH tunnel, and only set 0.0.0.0 after you understand exposure.
PLEX_MANAGER_HOST_BIND=127.0.0.1
PLEX_MANAGER_HOST_PORT=8000

# Optional hardening. When set, first-run setup ALSO requires this token; it is
# never required — a default install claims setup via the first Plex server owner
# to sign in. Generate a fresh value if you want it:
#     python -c "import secrets; print(secrets.token_urlsafe(32))"
# PLEX_MANAGER_SETUP_TOKEN=

# Development only. This does NOT merely skip the setup-token/API-key gates: it
# hands EVERY request an anonymous administrator context (is_admin=True) BEFORE
# session, expiry/revocation, CSRF, setup-token, and role/ownership checks. Any
# reachable client becomes a full admin with no credential and setup completion
# skips the Plex-owner identity assertion. NEVER enable it on a Docker, shared, or
# network-reachable listener — combine it only with the loopback default above.
PLEX_MANAGER_DEV_AUTH_BYPASS=false

# TLS-PROXY WARNING: if a reverse proxy terminates TLS and forwards HTTP here,
# you MUST set PLEX_MANAGER_AUTH_COOKIE_SECURE=true before startup. Unset means
# Secure is inferred from the request scheme the ASGI server reports: Plex
# Manager itself never reads X-Forwarded-Proto (uvicorn's own forwarded-header
# handling trusts loopback peers only, by default), so inference behind a TLS
# terminator is topology-dependent and commonly produces non-Secure cookies.
# Set false to force non-Secure cookies for an unusual direct-https setup.
# Values: true | false (leave unset to infer).
# PLEX_MANAGER_AUTH_COOKIE_SECURE=

# Extra HTTP Host names this app trusts, beyond what's always trusted for free:
# "localhost" and any loopback/private-range/link-local IP literal (127.0.0.1,
# 192.168.x.x, 10.x.x.x, etc. -- a browser only sends an IP literal as Host when
# it dialed that literal directly, so these can't be a DNS-rebinding target).
# Set this when a reverse proxy forwards a PUBLIC hostname to this app, or every
# request will get a 400 invalid_host. Comma-separated, case-insensitive:
# PLEX_MANAGER_ALLOWED_HOSTS=plexmgr.example.com,media.lan
#
# IMPORTANT (reverse proxies): the proxy must PRESERVE the client's original
# Host on the upstream request -- nginx: `proxy_set_header Host $host;` (the
# nginx default is $proxy_host, which rewrites Host to the private upstream
# address and would make every proxied request look trusted, delegating host
# validation entirely to your proxy's own vhost/server_name matching).
#
# The literal "*" disables Host validation entirely. Discouraged -- only for
# unusual topologies where the trust rules above genuinely don't fit.
# PLEX_MANAGER_ALLOWED_HOSTS=*

# How many trusted reverse-proxy hops sit in front of this app. Leave unset (0)
# unless you front the app with your own proxy: the sign-in throttle then keys on
# request.client.host alone, which is always the proxy's address behind a proxy,
# effectively a GLOBAL cap rather than per-IP. Set to the number of proxies you
# operate and trust to append to X-Forwarded-For (usually 1) so the throttle keys
# on the real client IP instead. Never set higher than the number of proxies you
# control.
# PLEX_MANAGER_TRUSTED_PROXY_HOPS=

# Host paths mounted into the container as /media and /downloads. In setup, choose
# Plex library folders under /media.
PLEX_MANAGER_MEDIA_ROOT=/srv/media
#
# PLEX_MANAGER_DOWNLOADS_ROOT has TWO roles, both using this LITERAL host path:
#   1. Docker binds it to /downloads inside Plex Manager (docker-compose.yml).
#   2. Plex Manager sends it UNCHANGED to qBittorrent as each torrent's save_path
#      (autoTMM off), so qBittorrent must be able to resolve and WRITE this exact
#      literal path — NOT its own /downloads view.
# qBittorrent placement by deployment:
#   - qBittorrent on the host: it writes the literal path directly. OK.
#   - qBittorrent in a separate container: mount the SAME literal path, e.g.
#     /srv/downloads:/srv/downloads. A /srv/downloads:/downloads mount is
#     INCOMPATIBLE when this value is /srv/downloads — qBittorrent sees only
#     /downloads and cannot write /srv/downloads, so the add fails or lands in an
#     unmounted path and Plex Manager cannot import.
#   - Remote qBittorrent: the literal path must exist remotely and point at storage
#     Plex Manager also sees at /downloads.
PLEX_MANAGER_DOWNLOADS_ROOT=/srv/downloads

# Database (defaults to SQLite in the mounted data volume). The app talks to the
# database asynchronously, so use the async driver form (sqlite+aiosqlite / for
# Postgres, postgresql+asyncpg). A plain sync URL is coerced to the async driver
# at startup, but the async form is the documented, unambiguous default.
#
# The stock Docker image includes PostgreSQL drivers. For a local non-Docker
# install, install the extra first:
#     pip install '.[postgres]'
# which pulls asyncpg (async app) + psycopg2-binary (sync Alembic migrations).
PLEX_MANAGER_DATABASE_URL=sqlite+aiosqlite:///./data/plex_manager.db

# Logging: DEBUG | INFO | WARNING | ERROR
PLEX_MANAGER_LOG_LEVEL=INFO

# Container image to run (override per host / channel).
# Canary host uses :edge, release host uses :stable.
PLEX_MANAGER_IMAGE=ghcr.io/lunchbox951/plex-manager:stable
# Optional first-party automatic-updater bootstrap. Automatic policy is OFF by
# default even when the sidecar is installed. To opt in to the Docker-authority
# boundary, create the secret once, keep it mode 0600, and start the Compose
# profile; all later scheduling and update controls are in the browser:
#
#   python -c "import secrets; print(secrets.token_urlsafe(32))" > .plex-manager-updater-token
#   chmod 600 .plex-manager-updater-token
#   # Uncomment PLEX_MANAGER_UPDATER_SECRET_SOURCE below in this .env file.
#   docker compose --profile auto-update up -d
#
# The updater has no published port. It is the only container with the Docker
# socket, which grants host-root-equivalent Docker control. The app receives only
# the shared file-mounted bearer secret. Rootless Docker or a NAS with a different
# socket path may override the HOST-side source below.
# Leave unset for the committed, deliberately invalid placeholder used by the
# normal profile-off deployment. Set only when opting in as shown above.
# PLEX_MANAGER_UPDATER_SECRET_SOURCE=.plex-manager-updater-token
PLEX_MANAGER_DOCKER_SOCKET=/var/run/docker.sock
# How often the sidecar asks the app-owned policy/coordinator for work.
# 1-30 seconds; the sidecar refuses to start above 30 because the app treats a
# heartbeat older than 45s as "updater unavailable", so slower polling would
# make the Status page falsely report a healthy sidecar as unavailable.
PLEX_MANAGER_UPDATER_POLL_SECONDS=30

# Leave unset. This app assumes a SINGLE process: several in-process registries
# (the same-hash download removal/reuse guards, the purge-vs-import path lock,
# the settings-rotation lock) hold no cross-process coordination, so running
# more than one worker or replica silently reopens the races they exist to
# close. WEB_CONCURRENCY (no PLEX_MANAGER_ prefix -- the common process-manager
# convention) is read ONLY to warn loudly at startup if it is set above 1; this
# app never uses it to size a worker pool itself. Do not set it above 1.
# WEB_CONCURRENCY=1
